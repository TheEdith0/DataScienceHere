   "source": [
    "#Probability of getting 6 heads out of 10 tosses\n",
    "from scipy.stats import binom\n",
    "\n",
    "prob=binom.pmf(k=6,n=10,p=0.5)\n",
    "# here pmf stnads for Probability Mass function\n",
    "print(prob)\n",
    "\n",
    "#can be used to check probabilty of user to click a button 40 times of of 100 times."
   ]
