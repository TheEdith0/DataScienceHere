import matplotlib.pyplot as plt

x=range(1,30)
y1=[y*2 for y in x]
y2=[y*y for y in x]
y3=[y*y*y for y in x]
y4=[y*8 for y in x]

plt.figure(figsize=(8,6))#Make it bigger

plt.subplot(2,2,1)
plt.plot(x,y1)
plt.xlabel("X")
plt.ylabel("Y")
plt.title("2X")

plt.subplot(2,2,2)
plt.plot(x,y2)
plt.xlabel("X")
plt.ylabel("Y")
plt.title("Y^2")

plt.subplot(2,2,3)
plt.plot(x,y3)
plt.xlabel("X")
plt.ylabel("Y")
plt.title("Y^3")

plt.subplot(2,2,4)
plt.plot(x,y4)
plt.xlabel("X")
plt.ylabel("Y")
plt.title("8X")

plt.tight_layout()#acoid collapsing
plt.show()


fig, axs =plt.subplots(1,2,figsize=(9,8))



